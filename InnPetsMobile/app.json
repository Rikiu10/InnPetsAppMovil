      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.InnPetsMobile",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "30bfbb92-c695-432e-b639-8367c92ea937"
      }
    },
    "owner": "pepitofifi"
